# =============================================================================
# TechNova API — environment variables
# =============================================================================
# 1. Copy this file to the same folder with the name `.env`:
#      copy .env.example .env   (Windows PowerShell / CMD)
#      cp .env.example .env     (macOS / Linux)
# 2. Replace every placeholder below with your real values.
# 3. Never commit `server/.env` — it is listed in `.gitignore`.
# =============================================================================

# development | production
NODE_ENV=development

# HTTP port for the Express API (default 5000 if omitted)
PORT=5000

# Browser origins allowed by CORS (must match the frontend URL exactly: scheme + host + port).
# For a single app:
CLIENT_ORIGIN=http://localhost:5173
# For production with multiple frontends (e.g. preview + production), use a comma list instead:
# CLIENT_ORIGINS=https://technova.vercel.app,https://www.yourdomain.com

# Behind a reverse proxy (Render, Railway, Fly, etc.) set so Express trusts X-Forwarded-For / Proto.
# TRUST_PROXY=true

# MongoDB connection string (Atlas or local).
# Atlas: Database → Connect → Drivers → copy the URI, replace <password> with your DB user password.
# Example:
# MONGODB_URI=mongodb+srv://MY_USER:MY_PASSWORD@cluster0.xxxxx.mongodb.net/technova?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/technova?retryWrites=true&w=majority

# Signing key for JWT access tokens — use a long random string (32+ characters).
# In production this MUST be set (the server will refuse to start with the dev placeholder).
JWT_SECRET=replace_with_a_long_random_secret

# Optional — access token lifetime (default 7d)
# JWT_EXPIRES_IN=7d
