# =============================================================================
# TechNova client (Vite) — environment variables
# =============================================================================
# Copy to `.env` or `.env.local` (both are gitignored in client/).
# Only variables prefixed with VITE_ are exposed to the browser.
# =============================================================================

# Production: full URL of the deployed API (include /api/v1).
# Example: https://technova-api.onrender.com/api/v1
# Development: omit or use /api/v1 (Vite dev server proxies /api → backend).
# VITE_API_BASE_URL=/api/v1

# Production: canonical site origin (no trailing slash). Used for SEO canonical + OG URLs.
# Example: https://technova.vercel.app
# VITE_APP_URL=

# Optional display name for titles / manifest
# VITE_SITE_NAME=TechNova
